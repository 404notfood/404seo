# ============================================
# SEO SaaS Platform — .gitignore
# ============================================

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- Build outputs ----------
# Next.js
site/.next/
site/out/

# API
apps/api/dist/

# Extension Chrome
apps/extension/dist/

# Packages
packages/*/dist/

# Workers
workers/dist/

# ---------- Env files ----------
.env
.env.*
!.env.example

# ---------- Database ----------
site/lib/generated/prisma/
*.db
*.sqlite

# ---------- Prisma ----------
site/prisma/migrations/**/migration_lock.toml

# ---------- OS files ----------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---------- IDE ----------
.vscode/settings.json
.vscode/launch.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- Debug logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Test & Coverage ----------
coverage/
.nyc_output/

# ---------- Keys & Secrets ----------
*.pem
*.key
*.cert
*.p12

# ---------- Misc ----------
.vercel
.turbo
.cache
*.log

# ---------- Claude Code ----------
.claude/
/blueprint
/memory
/md
/app
/public
