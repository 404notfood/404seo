# =============================================================================
# 404seo — Reseau Podman (Quadlet)
# =============================================================================
# Installe dans ~/.config/containers/systemd/ (rootless) puis :
#   systemctl --user daemon-reload
# Genere une unit systemd 404seo-network.service utilisee par les conteneurs.
# =============================================================================

[Unit]
Description=404seo internal network

[Network]
NetworkName=404seo
Driver=bridge
