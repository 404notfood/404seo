# =============================================================================
# 404seo — Variables d'environnement (deploiement Podman)
# =============================================================================
# Copier vers deployment/podman/.env et remplir.
# Ce fichier est injecte dans les conteneurs via --env-file (compose & Quadlet).
# NE JAMAIS commiter le .env rempli.
#
# Generer un secret : openssl rand -base64 32
# =============================================================================

# ── Domaine public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seo.404notfood.fr"
NEXT_PUBLIC_API_URL="https://seo.404notfood.fr"
BETTER_AUTH_URL="https://seo.404notfood.fr"

# ── Base de donnees (PostgreSQL natif HestiaCP) ───────────────────────────────
# IMPORTANT : depuis un conteneur, "localhost" = le conteneur lui-meme.
# On atteint le Postgres de l'hote via la passerelle Podman.
# host.containers.internal est resolu automatiquement par Podman vers l'hote.
# Postgres doit ecouter sur l'IP de la passerelle podman (voir README, section Postgres).
# Remplacer TON_MOT_DE_PASSE par le mot de passe choisi pour l'utilisateur seo_user.
DATABASE_URL="postgresql://seo_user:TON_MOT_DE_PASSE@host.containers.internal:5432/seo_db"

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="CHANGEME_openssl_rand_base64_32"

# ── Redis (conteneur, reseau interne) ─────────────────────────────────────────
# Vu depuis les conteneurs app : le hostname est le nom du service "redis".
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD="CHANGEME_redis_password"
# URL combinee (utilisee par certaines libs)
REDIS_URL="redis://:CHANGEME_redis_password@redis:6379"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="https://seo.404notfood.fr/api/google/callback"

# ── Emails (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="404seo <noreply@404notfood.fr>"

# ── IA (Claude) ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Monitoring (optionnel) ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Ports exposes sur l'hote (127.0.0.1 uniquement, derriere Nginx HestiaCP) ──
SITE_PORT=3030
API_PORT=4000
