# =============================================================================
# 404seo — .containerignore (Podman / Docker)
# =============================================================================
# Tout ce qui ne doit JAMAIS entrer dans le contexte de build des images.
# Garde les images legeres et le build rapide.
# =============================================================================

# Dependances (reinstallees dans l'image)
**/node_modules

# Artefacts de build Next.js
site/.next
site/out

# Logs & runtime
logs
*.log
.pm2

# Secrets / env (injectes via --env-file, jamais build-args)
**/.env
**/.env.*
!**/.env.example

# Git & CI
.git
.gitignore
.github

# Outils dev
.vscode
.idea
.claude
blueprint
*.md
!deployment/podman/README.md

# OS
.DS_Store
Thumbs.db

# Le dossier deployment lui-meme (pas besoin dans l'image)
deployment
!deployment/podman
