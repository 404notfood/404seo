# =============================================================================
# 404seo — Variables d'environnement (exemple)
# =============================================================================
# Copier ce fichier vers site/.env.local et remplir les valeurs
#
# Generer un secret : openssl rand -base64 32
# =============================================================================

# ── Base de donnees ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/seo_saas"

# ── Auth (BetterAuth) ─────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="<openssl rand -base64 32>"
BETTER_AUTH_URL="https://seo.404notfood.fr"

# ── API Fastify ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://seo.404notfood.fr"
API_PORT=4000

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=  # si Redis est protege par mot de passe

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Google OAuth (optionnel) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
