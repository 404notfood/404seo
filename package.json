{
  "name": "seo-saas",
  "private": true,
  "workspaces": [
    "site",
    "apps/*",
    "packages/*",
    "workers"
  ],
  "scripts": {
    "postinstall": "cd site && npx prisma generate",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "cd site && npx prisma migrate dev",
    "db:generate": "cd site && npx prisma generate",
    "db:studio": "cd site && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.8.12",
    "typescript": "^5.7.3"
  }
}
